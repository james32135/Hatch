# =============================================================================
# HATCH — Environment Variables (example)
# Copy secrets into repo-root `.env` (or packages/backend/.env).
# Values marked [DISCOVERED] are official / verified. Do not invent blanks.
# NEVER put parent SoDEX master/API private keys here for user trading.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=10000
HOST=0.0.0.0
LOG_LEVEL=info

# mainnet | testnet | mainnet-readonly
HATCH_DEFAULT_PROFILE=testnet

# Comma-separated origins (Phase 10: add Vercel URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Security / Auth
# -----------------------------------------------------------------------------
# [SECRET — generate] openssl rand -hex 32
JWT_SECRET=
JWT_TTL_SECONDS=604800

# [SECRET — generate] openssl rand -hex 32
CRON_SECRET=

# Instant halt for all SoDEX writes / allowance execution
KILL_SWITCH=false

# Max USD notional per allocate/relay order (production safety)
TRADING_MAX_NOTIONAL_USD=100

# Optional comma-separated parent wallets allowed to write (empty = all authenticated)
TRADING_ALLOWLIST=

# -----------------------------------------------------------------------------
# Database — Supabase PostgreSQL (or any Postgres)
# -----------------------------------------------------------------------------
# [SECRET — from Supabase Project Settings → Database]
DATABASE_URL=

# Session/direct URL for Prisma migrate (Supabase pooler :5432 or db.*.supabase.co:5432).
# Runtime app keeps using DATABASE_URL (transaction pooler :6543 is fine with @prisma/adapter-pg).
DIRECT_URL=

# -----------------------------------------------------------------------------
# Redis — Upstash REST (required in production)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional alternative to REST:
REDIS_URL=

# -----------------------------------------------------------------------------
# INTERNAL ENGINEERING SoDEX test credentials ONLY
# NOT for production user trading. Parents sign their own orders.
# Backend production paths must never custody user keys.
# Mainnet eng tests: hard cap 1.00 USDC (preferred 0.20) via MAINNET_TEST_GUARD
# -----------------------------------------------------------------------------
# SODEX_PRIVATE_KEY=
# SODEX_ADDRESS=
# SODEX_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# SoSoValue OpenAPI  [DISCOVERED]
# Docs: https://sosovalue-1.gitbook.io/sosovalue-api-doc
# -----------------------------------------------------------------------------
SOSO_API_BASE_URL=https://openapi.sosovalue.com/openapi/v1
# Header name is fixed by docs: x-soso-api-key
# [SECRET — https://sosovalue.com/developer/dashboard ]
# Alias accepted in code: SoSoValue_API_key
SOSO_API_KEY=

# Rate limit policy (official: 20 req/min, 100k/month per key)
SOSO_RATE_LIMIT_PER_MIN=18
SOSO_CACHE_TTL_SNAPSHOT_SECONDS=30
SOSO_CACHE_TTL_CONSTITUENTS_SECONDS=300
SOSO_CACHE_TTL_NEWS_SECONDS=30

# -----------------------------------------------------------------------------
# SoDEX Gateways  [DISCOVERED]
# Docs: https://sodex.com/documentation/trading-api/trading-api
# SDK (reference): https://github.com/sodex-tech/sodex-go-sdk-public
# Architecture: SODEX_ACCOUNT_ARCHITECTURE.md — NO global trading custody keys
# -----------------------------------------------------------------------------
SODEX_MAINNET_BASE_URL=https://mainnet-gw.sodex.dev
SODEX_TESTNET_BASE_URL=https://testnet-gw.sodex.dev

SODEX_MAINNET_SPOT_REST=https://mainnet-gw.sodex.dev/api/v1/spot
SODEX_MAINNET_PERPS_REST=https://mainnet-gw.sodex.dev/api/v1/perps
SODEX_MAINNET_SPOT_WS=wss://mainnet-gw.sodex.dev/ws/spot
SODEX_MAINNET_PERPS_WS=wss://mainnet-gw.sodex.dev/ws/perps

SODEX_TESTNET_SPOT_REST=https://testnet-gw.sodex.dev/api/v1/spot
SODEX_TESTNET_PERPS_REST=https://testnet-gw.sodex.dev/api/v1/perps
SODEX_TESTNET_SPOT_WS=wss://testnet-gw.sodex.dev/ws/spot
SODEX_TESTNET_PERPS_WS=wss://testnet-gw.sodex.dev/ws/perps

# App URLs (proof links / Enable Trading)
SODEX_MAINNET_APP_URL=https://sodex.com
SODEX_TESTNET_APP_URL=https://testnet.sodex.com

# Live mainnet symbol IDs verified 2026-07-11 via GET /spot/markets/symbols
SODEX_SYMBOL_VMAG7SSI_VUSDC_ID=3
SODEX_SYMBOL_VUSSI_VUSDC_ID=26
SODEX_SYMBOL_VMAG7SSI_VUSDC_NAME=vMAG7ssi_vUSDC
SODEX_SYMBOL_VUSSI_VUSDC_NAME=vUSSI_vUSDC

# Order policy
SODEX_ORDER_TYPE=LIMIT
SODEX_TIME_IN_FORCE=IOC
SODEX_SLIPPAGE_BPS=50

# DO NOT SET for user trading (forbidden as global custody):
# SODEX_PRIVATE_KEY / SODEX_ADDRESS / SODEX_ACCOUNT_ID
# Parent wallet signs; backend relays only.
# Optional future: per-user encrypted API-key material — never a shared house key for funds.

# -----------------------------------------------------------------------------
# ValueChain EVM  [DISCOVERED]
# Docs: https://sodex.com/documentation/about-valuechain/how-valuechain-works/about-valuechain-evm
# -----------------------------------------------------------------------------
VALUECHAIN_MAINNET_CHAIN_ID=286623
VALUECHAIN_MAINNET_RPC_URL=https://mainnet.valuechain.xyz
VALUECHAIN_MAINNET_WS_URL=wss://mainnet-ws.valuechain.xyz
VALUECHAIN_MAINNET_EXPLORER_URL=https://main-scan.valuechain.xyz
VALUECHAIN_MAINNET_CURRENCY_SYMBOL=SOSO

VALUECHAIN_TESTNET_CHAIN_ID=138565
VALUECHAIN_TESTNET_RPC_URL=https://testnet-v2.valuechain.xyz
VALUECHAIN_TESTNET_WS_URL=wss://testnet-v2-ws.valuechain.xyz
VALUECHAIN_TESTNET_EXPLORER_URL=https://test-scan.valuechain.xyz
VALUECHAIN_TESTNET_CURRENCY_SYMBOL=SOSO

# WSOSO (immutable vanity) [DISCOVERED]
WSOSO_ADDRESS=0x5050505050505050505050505050505050505050

# HATCH contracts — fill after Foundry deploy
HATCH_LOG_ADDRESS_MAINNET=0x06a8ADeB3d1d1a4160606967308C275a627E4fCB
HATCH_LOG_ADDRESS_TESTNET=0xB4483128Bf95aa63621cB9EcA7f5d22a0d546b6C
HATCH_SCHEDULE_ADDRESS_MAINNET=0xfdC9A9F19441f10729769393CBBD6d870802Ace9
HATCH_SCHEDULE_ADDRESS_TESTNET=0x3db8750EE3a397b5A8A4e1842Bfb69f511342C6b

# [SECRET — deployer for contracts only; NOT SoDEX user trading]
VALUECHAIN_DEPLOYER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Base (SSI token home)  [DISCOVERED]
# -----------------------------------------------------------------------------
BASE_CHAIN_ID=8453
BASE_RPC_URL=https://mainnet.base.org
BASE_EXPLORER_URL=https://basescan.org

# SSI / SOSO token addresses on Base [DISCOVERED via BaseScan + official listings]
MAG7_SSI_TOKEN_ADDRESS=0x9E6A46f294bB67c20F1D1E7AfB0bBEf614403B55
USSI_TOKEN_ADDRESS=0x3a46ed8FCeb6eF1ADA2E4600A522AE7e24D2Ed18
SMAG7_SSI_TOKEN_ADDRESS=0x3d8f0ddb4bb9332Cb89dEC22d273d9be1a91530b
SOSO_TOKEN_ADDRESS_BASE=0x624e2e7fdc8903165f64891672267ab0fcb98831
SOSO_TOKEN_ADDRESS_ETHEREUM=0x76a0e27618462bdac7a29104bdcfff4e6bfcea2d

# SSI Router / Staking — NOT in public docs; leave blank until verified
SSI_ROUTER_ADDRESS=
SSI_STAKING_ADDRESS=

# -----------------------------------------------------------------------------
# AI providers — NVIDIA primary  [DISCOVERED]
# Docs: https://docs.api.nvidia.com/  |  https://build.nvidia.com/
# OpenAI-compatible base: https://integrate.api.nvidia.com/v1
# Primary free coding/reasoning: deepseek-ai/deepseek-v4-flash
# -----------------------------------------------------------------------------
# [SECRET — https://build.nvidia.com/settings ]
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_MODEL_ALT=openai/gpt-oss-120b
NVIDIA_MODEL_ALT2=meta/llama-3.3-70b-instruct

# Fallback providers (OpenAI-compatible) — keys already used in project .env
# [SECRET]
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# [SECRET]
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama3.3-70b

# [SECRET]
SAMBANOVA_API_KEY=
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

# Optional extras (not in primary failover chain)
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

AI_TIMEOUT_MS=45000
AI_MAX_TOKENS=1024
AI_CIRCUIT_FAILURE_THRESHOLD=3
AI_CIRCUIT_COOLDOWN_MS=60000
AI_MAX_RETRIES_PER_PROVIDER=2

# -----------------------------------------------------------------------------
# Jobs
# -----------------------------------------------------------------------------
SNAPSHOT_INTERVAL_MS=60000
ALLOWANCE_CRON=0 12 * * *
HEARTBEAT_PATH=/api/internal/heartbeat

# -----------------------------------------------------------------------------
# Frontend (Phase 10 — Vercel) — do not implement until backend complete
# -----------------------------------------------------------------------------
# VITE_API_URL=https://YOUR-SERVICE.onrender.com
# VITE_DEFAULT_ENVIRONMENT=mainnet
# VITE_REOWN_PROJECT_ID=
