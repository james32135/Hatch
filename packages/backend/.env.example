# =============================================================================
# HATCH — Environment Variables
# Copy to packages/backend/.env and fill secrets listed in ENVIRONMENT_REQUIREMENTS.md
# Values below marked [DISCOVERED] are official / verified. Do not invent replacements.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=10000
HOST=0.0.0.0
LOG_LEVEL=info

# mainnet | testnet | mainnet-readonly
HATCH_DEFAULT_PROFILE=testnet

# Comma-separated origins (Phase 10: add Vercel URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Security / Auth
# -----------------------------------------------------------------------------
# [SECRET — generate] openssl rand -hex 32
JWT_SECRET=
JWT_TTL_SECONDS=604800

# [SECRET — generate] openssl rand -hex 32
CRON_SECRET=

# Instant halt for all SoDEX writes / allowance execution
KILL_SWITCH=false

# Max USD notional per allocate/relay order (production safety)
TRADING_MAX_NOTIONAL_USD=100

# Optional comma-separated parent wallets allowed to write (empty = all authenticated)
TRADING_ALLOWLIST=

# -----------------------------------------------------------------------------
# Database — Render PostgreSQL
# -----------------------------------------------------------------------------
# [SECRET — from Render dashboard after creating Postgres]
DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis — Upstash (preferred) or Render Redis
# -----------------------------------------------------------------------------
# [SECRET — from Upstash]
REDIS_URL=
# Optional Upstash REST (if using REST client instead of ioredis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# SoSoValue OpenAPI  [DISCOVERED]
# Docs: https://sosovalue-1.gitbook.io/sosovalue-api-doc
# -----------------------------------------------------------------------------
SOSO_API_BASE_URL=https://openapi.sosovalue.com/openapi/v1
# Header name is fixed by docs: x-soso-api-key
# [SECRET — https://sosovalue.com/developer/dashboard ]
SOSO_API_KEY=

# Rate limit policy (official: 20 req/min, 100k/month per key)
SOSO_RATE_LIMIT_PER_MIN=18
SOSO_CACHE_TTL_SNAPSHOT_SECONDS=30
SOSO_CACHE_TTL_CONSTITUENTS_SECONDS=300
SOSO_CACHE_TTL_NEWS_SECONDS=30

# -----------------------------------------------------------------------------
# SoDEX Gateways  [DISCOVERED]
# Docs: https://sodex.com/documentation/trading-api/trading-api
# SDK: https://github.com/sodex-tech/sodex-go-sdk-public
# -----------------------------------------------------------------------------
SODEX_MAINNET_BASE_URL=https://mainnet-gw.sodex.dev
SODEX_TESTNET_BASE_URL=https://testnet-gw.sodex.dev

SODEX_MAINNET_SPOT_REST=https://mainnet-gw.sodex.dev/api/v1/spot
SODEX_MAINNET_PERPS_REST=https://mainnet-gw.sodex.dev/api/v1/perps
SODEX_MAINNET_SPOT_WS=wss://mainnet-gw.sodex.dev/ws/spot
SODEX_MAINNET_PERPS_WS=wss://mainnet-gw.sodex.dev/ws/perps

SODEX_TESTNET_SPOT_REST=https://testnet-gw.sodex.dev/api/v1/spot
SODEX_TESTNET_PERPS_REST=https://testnet-gw.sodex.dev/api/v1/perps
SODEX_TESTNET_SPOT_WS=wss://testnet-gw.sodex.dev/ws/spot
SODEX_TESTNET_PERPS_WS=wss://testnet-gw.sodex.dev/ws/perps

# App URLs (proof links)
SODEX_MAINNET_APP_URL=https://sodex.com
SODEX_TESTNET_APP_URL=https://testnet.sodex.com

# Live mainnet symbol IDs verified 2026-07-11 via GET /spot/markets/symbols
SODEX_SYMBOL_VMAG7SSI_VUSDC_ID=3
SODEX_SYMBOL_VUSSI_VUSDC_ID=26
SODEX_SYMBOL_VMAG7SSI_VUSDC_NAME=vMAG7ssi_vUSDC
SODEX_SYMBOL_VUSSI_VUSDC_NAME=vUSSI_vUSDC

# Order policy
SODEX_ORDER_TYPE=LIMIT
SODEX_TIME_IN_FORCE=IOC
SODEX_SLIPPAGE_BPS=50

# Optional server-side SoDEX API key (automation only — NOT parent funds)
# X-API-Key header carries the NAME, not the address
# [SECRET]
SODEX_API_KEY_NAME=
SODEX_API_KEY_PRIVATE_KEY=
SODEX_MASTER_WALLET_ADDRESS=

# -----------------------------------------------------------------------------
# ValueChain EVM  [DISCOVERED]
# Docs: https://sodex.com/documentation/about-valuechain/how-valuechain-works/about-valuechain-evm
# -----------------------------------------------------------------------------
VALUECHAIN_MAINNET_CHAIN_ID=286623
VALUECHAIN_MAINNET_RPC_URL=https://mainnet.valuechain.xyz
VALUECHAIN_MAINNET_WS_URL=wss://mainnet-ws.valuechain.xyz
VALUECHAIN_MAINNET_EXPLORER_URL=https://main-scan.valuechain.xyz
VALUECHAIN_MAINNET_CURRENCY_SYMBOL=SOSO

VALUECHAIN_TESTNET_CHAIN_ID=138565
VALUECHAIN_TESTNET_RPC_URL=https://testnet-v2.valuechain.xyz
VALUECHAIN_TESTNET_WS_URL=wss://testnet-v2-ws.valuechain.xyz
VALUECHAIN_TESTNET_EXPLORER_URL=https://test-scan.valuechain.xyz
VALUECHAIN_TESTNET_CURRENCY_SYMBOL=SOSO

# WSOSO (immutable vanity) [DISCOVERED]
WSOSO_ADDRESS=0x5050505050505050505050505050505050505050

# HATCH contracts — fill after Phase 3 deploy
HATCH_LOG_ADDRESS_MAINNET=
HATCH_LOG_ADDRESS_TESTNET=
HATCH_SCHEDULE_ADDRESS_MAINNET=
HATCH_SCHEDULE_ADDRESS_TESTNET=

# [SECRET — deployer for contracts]
VALUECHAIN_DEPLOYER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Base (SSI token home)  [DISCOVERED]
# -----------------------------------------------------------------------------
BASE_CHAIN_ID=8453
BASE_RPC_URL=https://mainnet.base.org
BASE_EXPLORER_URL=https://basescan.org

# SSI / SOSO token addresses on Base [DISCOVERED via BaseScan + official listings]
MAG7_SSI_TOKEN_ADDRESS=0x9E6A46f294bB67c20F1D1E7AfB0bBEf614403B55
USSI_TOKEN_ADDRESS=0x3a46ed8FCeb6eF1ADA2E4600A522AE7e24D2Ed18
SMAG7_SSI_TOKEN_ADDRESS=0x3d8f0ddb4bb9332Cb89dEC22d273d9be1a91530b
SOSO_TOKEN_ADDRESS_BASE=0x624e2e7fdc8903165f64891672267ab0fcb98831
SOSO_TOKEN_ADDRESS_ETHEREUM=0x76a0e27618462bdac7a29104bdcfff4e6bfcea2d

# SSI Router / Staking — NOT in public docs; discover via SSI frontend + ssi-protocol repo
# Leave blank until verified — do not invent
SSI_ROUTER_ADDRESS=
SSI_STAKING_ADDRESS=

# -----------------------------------------------------------------------------
# AI providers (Education Agent) — at least one required
# -----------------------------------------------------------------------------
# [SECRET]
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# [SECRET — optional fallback]
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# [SECRET — optional]
GROQ_API_KEY=
OPENROUTER_API_KEY=

AI_TIMEOUT_MS=30000
AI_MAX_TOKENS=400

# -----------------------------------------------------------------------------
# Jobs
# -----------------------------------------------------------------------------
SNAPSHOT_INTERVAL_MS=60000
ALLOWANCE_CRON=0 12 * * *
HEARTBEAT_PATH=/api/internal/heartbeat

# -----------------------------------------------------------------------------
# Frontend (Phase 10 — Vercel)  [DISCOVERED patterns]
# -----------------------------------------------------------------------------
# VITE_API_URL=https://YOUR-SERVICE.onrender.com
# VITE_DEFAULT_ENVIRONMENT=mainnet
# VITE_REOWN_PROJECT_ID=   # [SECRET — https://cloud.reown.com ]
# VITE_WALLETCONNECT_PROJECT_ID=
